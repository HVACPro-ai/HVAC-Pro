generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum CategoryType {
  INCOME
  BILL
  SUBSCRIPTION
  DISCRETIONARY
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

model User {
  id                   String                 @id @default(cuid())
  email                String?                @unique
  emailVerified        DateTime?
  name                 String?
  image                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  admin                Boolean                @default(false)
  stripeCustomerId     String?

  accounts             Account[]
  sessions             Session[]
  memberships          HouseholdMember[]
  invitations          HouseholdInvite[]      @relation("InvitedUser")
  webPushSubscriptions WebPushSubscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Household {
  id            String             @id @default(cuid())
  name          String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  couplesMode   Boolean            @default(false)

  members       HouseholdMember[]
  invites       HouseholdInvite[]
  plaidItems    PlaidItem[]
  bankAccounts  BankAccount[]
  transactions  Transaction[]
  budgets       Budget[]
  goals         Goal[]
  subscription  Subscription?
  merchantAliases MerchantAlias[]
}

model HouseholdMember {
  id           String      @id @default(cuid())
  householdId  String
  userId       String
  role         MemberRole  @default(MEMBER)
  funBudgetCents Int       @default(0)
  createdAt    DateTime    @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
}

model HouseholdInvite {
  id              String      @id @default(cuid())
  householdId     String
  email           String
  invitedByUserId String
  token           String      @unique
  status          String      @default("pending")
  createdAt       DateTime    @default(now())
  acceptedAt      DateTime?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitedUser", fields: [invitedByUserId], references: [id])
}

model PlaidItem {
  id              String     @id @default(cuid())
  plaidItemId     String     @unique
  accessTokenEnc  String
  institutionId   String?
  environment     String
  lastSyncedAt    DateTime?
  householdId     String

  household   Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  accounts    BankAccount[]
}

model BankAccount {
  id                    String        @id @default(cuid())
  plaidAccountId        String        @unique
  name                  String
  officialName          String?
  mask                  String?
  type                  String?
  subtype               String?
  currency              String?      @default("USD")
  availableBalanceCents Int?
  currentBalanceCents   Int?
  householdId           String
  itemId                String

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  item      PlaidItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id                 String        @id @default(cuid())
  plaidTransactionId String?       @unique
  bankAccountId      String
  householdId        String
  amountCents        Int
  date               DateTime
  name               String
  merchantName       String?
  originalDescription String?
  pending            Boolean?      @default(false)
  category           CategoryType?
  isRecurring        Boolean       @default(false)
  merchantAliasId    String?

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  household   Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  merchantAlias MerchantAlias? @relation(fields: [merchantAliasId], references: [id])

  @@index([householdId, date])
}

model MerchantAlias {
  id          String        @id @default(cuid())
  merchantKey String        @unique
  alias       String
  category    CategoryType?
  householdId String?

  household Household? @relation(fields: [householdId], references: [id])
  transactions Transaction[]
}

model Budget {
  id                  String    @id @default(cuid())
  householdId         String
  month               DateTime
  monthlyIncomeCents  Int       @default(0)
  fixedBillsCents     Int       @default(0)
  discretionaryCents  Int       @default(0)
  extraCents          Int       @default(0)

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, month])
}

model Goal {
  id             String   @id @default(cuid())
  householdId    String
  name           String
  targetCents    Int
  currentCents   Int      @default(0)
  priority       Int
  active         Boolean  @default(false)
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String
  amountCents Int
  date      DateTime @default(now())
  source    String

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String              @id @default(cuid())
  householdId          String              @unique
  status               SubscriptionStatus  @default(INCOMPLETE)
  stripeCustomerId     String              @unique
  stripeSubscriptionId String?
  priceId              String
  currentPeriodEnd     DateTime?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
